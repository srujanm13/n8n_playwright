{
  "name": "n8n_playwright",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ci": "npx playwright install --with-deps && playwright test --reporter=github",
    "test:docker": "npx playwright install --with-deps && playwright test --reporter=list",
    "test:debug": "pwsh -NoExit -Command \"npx playwright test --debug\""
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0"
  }
}
